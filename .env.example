# LLM API configuration (supports any LLM with OpenAI SDK format)
# Recommended: Alibaba Bailian Platform Qwen-plus model: https://bailian.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Backend Configuration =====
# Backend selection: 'cloud' for Zep Cloud | 'graphiti' for local Neo4j
ZEP_BACKEND=cloud

# Zep Cloud configuration (required when ZEP_BACKEND=cloud)
# Free monthly quota is sufficient to get started: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Graphiti / Neo4j Local Configuration (required when ZEP_BACKEND=graphiti) =====
# Start Neo4j: docker-compose -f docker-compose.local.yml up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Graphiti requires an OpenAI-compatible LLM for entity extraction
# OPENAI_API_KEY/OPENAI_BASE_URL are automatically mapped from LLM_API_KEY/LLM_BASE_URL
# To configure a separate LLM for Graphiti, explicitly set:
# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Graphiti default models (explicit configuration recommended to avoid incompatibility with OpenAI default model names)
# - DashScope chat: qwen3-max
# - DashScope embedding: text-embedding-v4
GRAPHITI_LLM_MODEL=qwen3-max
GRAPHITI_EMBEDDING_MODEL=text-embedding-v4

# Search re-ranking configuration (optional)
# Non-standard OpenAI APIs (e.g. DashScope) automatically fall back to RRF re-ranking
# If your API supports logprobs, you can force cross_encoder usage:
# GRAPHITI_FORCE_CROSS_ENCODER=true

# ===== Boost LLM Configuration (optional) =====
LLM_BOOST_API_KEY=your_boost_api_key_here
LLM_BOOST_BASE_URL=https://another-api-provider.com/v1
LLM_BOOST_MODEL_NAME=gpt-4o-mini
